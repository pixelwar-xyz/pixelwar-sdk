{
  "name": "pixelwar-sdk",
  "version": "3.0.0",
  "description": "TypeScript SDK and terminal client for PixelWar.xyz — the x402-powered pixel world",
  "keywords": [
    "x402",
    "pixelwar",
    "usdc",
    "agent",
    "payments",
    "solana",
    "base"
  ],
  "homepage": "https://pixelwar.xyz",
  "bugs": {
    "url": "https://github.com/pixelwar-xyz/pixelwar-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pixelwar-xyz/pixelwar-sdk.git"
  },
  "license": "MIT",
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pixelwar": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.15",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "viem": "^2.34.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
